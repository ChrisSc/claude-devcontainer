# Template for .devcontainer/.env — the REAL file is generated by `make env`
# (or .devcontainer/gen-env.sh) with a strong random password and is gitignored.
# This example is committed for documentation only; it holds no real secret.
#
# Both the db sidecar and claude-code load .env via compose `env_file`.

# --- db sidecar (postgres entrypoint) ---
POSTGRES_USER=claude
POSTGRES_PASSWORD=changeme-generated-by-make-env
POSTGRES_DB=claude

# --- claude-code (libpq client vars + URL) ---
PGHOST=db
PGPORT=5432
PGUSER=claude
PGPASSWORD=changeme-generated-by-make-env
PGDATABASE=claude
DATABASE_URL=postgresql://claude:changeme-generated-by-make-env@db:5432/claude
