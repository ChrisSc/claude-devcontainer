# Claude Code per-project harness state (scheduled-task locks, local session
# data, worktrees). Local-only — never push.
.claude/*
# Exception: the versioned audit/remediation Workflow scripts are tracked so they
# resolve as named workflows from .claude/workflows/ while staying in the repo.
!.claude/workflows/

# Generated DB secrets (strong password). Never commit; .env.example is the
# tracked template. Matches .env in any directory.
.env

# Personal firewall allowlist (may hold LAN IPs / private hosts). The tracked
# template is extra-allowlist.txt.example; the real file is generated by
# gen-allowlist.sh and is gitignored.
.devcontainer/config/extra-allowlist.txt

# Local database backups produced by `make db-dump`.
db-backups/

# OS / editor cruft
.DS_Store
*.swp
